NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# Server-only — required for founder admin dashboard, inboxes, and moderation queue
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
NEXT_PUBLIC_SITE_URL=https://charid.app
# Optional — enables live AI scene suggestions (falls back to template suggestions without it)
OPENAI_API_KEY=
# Optional — defaults to gpt-4o-mini
OPENAI_TEXT_MODEL=gpt-4o-mini

# Stripe billing (server-only except publishable key)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Price IDs from Stripe Dashboard → Products (test mode for dev)
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=
